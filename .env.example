# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_SECRET=...
# Komma-separierte Liste deiner Telegram-User-IDs (z.B. "12345678,87654321").
# Wenn gesetzt, akzeptiert der Bot nur Nachrichten von diesen IDs.
# Eigene ID herausfinden: in Telegram /start an @userinfobot schicken.
# Leer lassen -> Allowlist deaktiviert (nicht empfohlen für öffentliche Webhooks).
TELEGRAM_ALLOWED_USER_IDS=

# Chat-ID fuer Admin-Fehler-DMs bei dauerhaften Worker-Fehlern (optional).
# Leer = nur Log, keine Telegram-Benachrichtigung an den Admin.
# Eigene ID: /start an @userinfobot.
TELEGRAM_ADMIN_CHAT_ID=

# Long-Polling-Modus (Alternative zum Webhook — keine oeffentliche URL noetig).
# Greift nur, wenn der Poller laeuft: `docker compose --profile polling up`
# oder lokal `python -m app.telegram.polling`. Long-Poll-Fenster in Sekunden.
TELEGRAM_POLLING_TIMEOUT=25

# LLM — choose one
LLM_PROVIDER=openai          # or: ollama
OPENAI_API_KEY=...
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Obsidian — point at your personal vault, not vault.example/
OBSIDIAN_VAULT_HOST_PATH=/Users/you/Obsidian/Seiton-Brain
OBSIDIAN_VAULT_PATH=/vault   # inside Docker; use host path when running locally

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/seitonbrain

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# REST API (/v1/*). Leer lassen = API deaktiviert. Fuer n8n/externe Tools setzen:
SEITON_API_KEY=change-me-to-a-long-random-string
# Header bei Requests: X-Seiton-Api-Key: <derselbe Wert>

# Outbound Webhooks (optional). Leer = deaktiviert.
# n8n: Webhook-Trigger-Node — Event-Typ im JSON-Feld "event" filtern.
SEITON_WEBHOOK_URL=

# Logging (optional)
LOG_LEVEL=INFO
# true = JSON (Docker/Production), false = lesbares Text-Format lokal
LOG_JSON=true