# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_SECRET=...
# Komma-separierte Liste deiner Telegram-User-IDs (z.B. "12345678,87654321").
# Wenn gesetzt, akzeptiert der Bot nur Nachrichten von diesen IDs.
# Eigene ID herausfinden: in Telegram /start an @userinfobot schicken.
# Leer lassen -> Allowlist deaktiviert (nicht empfohlen für öffentliche Webhooks).
TELEGRAM_ALLOWED_USER_IDS=

# LLM — choose one
LLM_PROVIDER=openai          # or: ollama
OPENAI_API_KEY=...
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Obsidian — point at your personal vault, not vault.example/
OBSIDIAN_VAULT_HOST_PATH=/Users/you/Obsidian/Seiton-Brain
OBSIDIAN_VAULT_PATH=/vault   # inside Docker; use host path when running locally

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/seitonbrain

# Redis / Celery
REDIS_URL=redis://redis:6379/0